{
    "version": 2,
    "functions": {
        "api/index.ts": {
            "runtime": "@vercel/node"
        }
    },
    "routes": [
        {
            "src": "^/health$",
            "dest": "/api/index.ts"
        },
        {
            "src": "^/api/(.*)$",
            "dest": "/api/index.ts"
        }
    ]
}
